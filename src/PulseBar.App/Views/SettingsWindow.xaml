<Window x:Class="PulseBar.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Loc[Settings_Title]}"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0"
                   VerticalAlignment="Center" Margin="0,0,0,12"
                   Text="{Binding Loc[Settings_Language]}" />
        <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"
                  ItemsSource="{Binding Languages}"
                  DisplayMemberPath="DisplayName"
                  SelectedValuePath="Code"
                  SelectedValue="{Binding SelectedLanguage}" />

        <TextBlock Grid.Row="1" Grid.Column="0"
                   VerticalAlignment="Center" Margin="0,0,0,12"
                   Text="{Binding Loc[Settings_Layout]}" />
        <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"
                  ItemsSource="{Binding Layouts}"
                  SelectedItem="{Binding SelectedLayout}" />

        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button MinWidth="88" Margin="0,0,8,0"
                    Content="{Binding Loc[Settings_Save]}"
                    Click="OnSaveClick" />
            <Button MinWidth="88"
                    Content="{Binding Loc[Settings_Cancel]}"
                    Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
