<Window x:Class="PulseBar.App.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PulseBar Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="{Binding Loc[Tray_Refresh]}" Click="OnRefreshClick" />
            <MenuItem Header="{Binding Loc[Tray_Settings]}" Click="OnSettingsClick" />
            <Separator />
            <MenuItem Header="{Binding Loc[Tray_Exit]}" Click="OnExitClick" />
        </ContextMenu>
    </Window.ContextMenu>
    <Border Background="#B31A1A1A"
            CornerRadius="4"
            Padding="8,1"
            Opacity="{Binding Bar.BarOpacity}">
        <StackPanel>
            <TextBlock Text="{Binding Bar.SystemLine}"
                       FontFamily="{Binding Bar.FontFamily}"
                       FontSize="{Binding Bar.FontSize}"
                       Foreground="#F0FFFFFF" />
            <TextBlock Text="{Binding Bar.ProviderLine}"
                       FontFamily="{Binding Bar.FontFamily}"
                       FontSize="{Binding Bar.FontSize}"
                       Foreground="#C0FFFFFF"
                       Visibility="{Binding Bar.ShowProviderLine, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>
    </Border>
</Window>
