<Window x:Class="PulseBar.App.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PulseBar.App.Converters"
        Title="PulseBar Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:SegmentKindToBrushConverter x:Key="KindToBrush" />
        <converters:SegmentKindToFontWeightConverter x:Key="KindToWeight" />
        <DataTemplate x:Key="SegmentTemplate">
            <TextBlock Text="{Binding Text}"
                       Foreground="{Binding Kind, Converter={StaticResource KindToBrush}}"
                       FontWeight="{Binding Kind, Converter={StaticResource KindToWeight}}" />
        </DataTemplate>
        <ItemsPanelTemplate x:Key="HorizontalPanel">
            <StackPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
    </Window.Resources>
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="{Binding Loc[Tray_Refresh]}" Click="OnRefreshClick" />
            <MenuItem Header="{Binding Loc[Tray_Settings]}" Click="OnSettingsClick" />
            <Separator />
            <MenuItem Header="{Binding Loc[Tray_Exit]}" Click="OnExitClick" />
        </ContextMenu>
    </Window.ContextMenu>
    <Border Background="#B31A1A1A"
            CornerRadius="4"
            Padding="8,1"
            Opacity="{Binding Bar.BarOpacity}"
            ToolTip="{Binding Bar.TooltipText}"
            ToolTipService.ShowDuration="30000">
        <StackPanel>
            <ItemsControl ItemsSource="{Binding Bar.SystemSegments}"
                          ItemTemplate="{StaticResource SegmentTemplate}"
                          ItemsPanel="{StaticResource HorizontalPanel}"
                          FontFamily="{Binding Bar.FontFamily}"
                          FontSize="{Binding Bar.FontSize}"
                          IsHitTestVisible="False" />
            <ItemsControl ItemsSource="{Binding Bar.ProviderSegments}"
                          ItemTemplate="{StaticResource SegmentTemplate}"
                          ItemsPanel="{StaticResource HorizontalPanel}"
                          FontFamily="{Binding Bar.FontFamily}"
                          FontSize="{Binding Bar.FontSize}"
                          IsHitTestVisible="False"
                          Visibility="{Binding Bar.ShowProviderLine, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>
    </Border>
</Window>
