<Window x:Class="PulseBar.App.Views.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Loc[Detail_Title]}"
        Width="400"
        SizeToContent="Height"
        WindowStyle="ToolWindow"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <TabControl x:Name="Tabs" Margin="4">
        <TabItem Header="{Binding Loc[Detail_SystemTab]}">
            <StackPanel Margin="12">
                <TextBlock Text="{Binding Loc[Detail_CpuHistory]}" FontWeight="SemiBold" />
                <Border BorderBrush="#40808080" BorderThickness="1" Margin="0,4,0,10"
                        Background="#0D808080" HorizontalAlignment="Left">
                    <Canvas Width="336" Height="60" ClipToBounds="True">
                        <Polyline Points="{Binding CpuPoints}"
                                  Stroke="#00C88C" StrokeThickness="1.5" />
                    </Canvas>
                </Border>
                <TextBlock Text="{Binding CpuText}" Margin="0,2" FontFamily="Consolas" />
                <TextBlock Text="{Binding MemoryText}" Margin="0,2" FontFamily="Consolas" />
                <TextBlock Text="{Binding GpuText}" Margin="0,2" FontFamily="Consolas" />
                <TextBlock Text="{Binding VramText}" Margin="0,2" FontFamily="Consolas" />
                <TextBlock Text="{Binding DiskText}" Margin="0,2" FontFamily="Consolas" />
                <TextBlock Text="{Binding NetworkText}" Margin="0,2" FontFamily="Consolas" />
            </StackPanel>
        </TabItem>
        <TabItem Header="{Binding Loc[Detail_AiTab]}">
            <StackPanel Margin="12">
                <ItemsControl ItemsSource="{Binding Cards}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#40808080" BorderThickness="1" CornerRadius="4"
                                    Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" />
                                        <TextBlock Text="{Binding Status}" Foreground="#909090"
                                                   HorizontalAlignment="Right" FontSize="11" />
                                    </DockPanel>
                                    <ItemsControl ItemsSource="{Binding Lines}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Margin="0,1" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <WrapPanel Margin="0,4,0,0">
                    <WrapPanel.Resources>
                        <Style TargetType="Button">
                            <Setter Property="MinWidth" Value="120" />
                            <Setter Property="Margin" Value="0,0,8,8" />
                            <Setter Property="Padding" Value="10,4" />
                        </Style>
                    </WrapPanel.Resources>
                    <Button Content="{Binding Loc[Detail_CodexLogin]}" Click="OnCodexLoginClick" />
                    <Button Content="{Binding Loc[Detail_ClaudeLogin]}" Click="OnClaudeLoginClick" />
                </WrapPanel>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
